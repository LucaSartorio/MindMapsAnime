# Modulo "Segnala un bug / Proponi miglioria"
# Access key gratuita di Web3Forms (https://web3forms.com): inserisci la tua email,
# ricevi la chiave e incollala qui. In produzione impostala anche nelle
# Environment Variables del progetto su Vercel.
VITE_WEB3FORMS_ACCESS_KEY=

# Pagina "Supportaci": link alla donazione PayPal (PayPal.me o bottone Donate).
# Es. https://www.paypal.com/paypalme/iltuonome  oppure  https://www.paypal.com/donate/?hosted_button_id=XXXX
VITE_PAYPAL_URL=
